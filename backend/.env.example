# Copy this file to .env and fill in your details. .env is gitignored.

# --- User 1 (required) ---
GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=your-password-here
GARMIN_TOKEN_STORE=.garmin_tokens
USER1_NAME=            # optional default display name (editable in the dashboard)

# --- User 2 (optional) — fill in to enable a second profile ---
GARMIN_EMAIL_2=
GARMIN_PASSWORD_2=
GARMIN_TOKEN_STORE_2=.garmin_tokens_2
USER2_NAME=

# Path to the SQLite database file (relative to backend/ or absolute)
DB_PATH=garmin.db

# Flask
FLASK_PORT=5000
