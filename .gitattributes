# Normalize line endings: store LF in the repo for all text files.
* text=auto

# These run on the Linux Raspberry Pi — force LF in the working tree too,
# so a CRLF checkout on Windows can never break them on the Pi.
*.sh        text eol=lf
*.service   text eol=lf
*.timer     text eol=lf
*.conf      text eol=lf
# deploy/*.template are rendered into /etc by install.sh — a CRLF checkout would
# be copied straight into a systemd unit, which refuses to parse it.
*.template  text eol=lf

# Common source types (LF in repo).
*.py    text
*.js    text
*.jsx   text
*.json  text
*.css   text
*.html  text
*.md    text
*.sql   text
